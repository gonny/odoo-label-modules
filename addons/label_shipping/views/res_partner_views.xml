<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_partner_form_shipping" model="ir.ui.view">
    <field name="name">res.partner.form.shipping</field>
    <field name="model">res.partner</field>
    <field name="inherit_id" ref="base.view_partner_form"/>
    <field name="arch" type="xml">
      <xpath expr="//page[@name='internal_notes']" position="before">
        <page string="Doprava" name="label_shipping_carrier" invisible="type != 'delivery'">
          <group>
            <group string="Preferovaný dopravce">
              <field name="label_preferred_carrier"/>
              <field name="label_carrier_service"/>
            </group>
            <group string="Výdejní místo">
              <button name="action_open_pickup_widget"
                      type="object"
                      string="Vybrat výdejní místo"
                      class="btn-link"
                      icon="fa-map-marker"
                      invisible="label_preferred_carrier in ('none', False)"/>
              <field name="label_pickup_point_id"/>
              <field name="label_pickup_point_name"/>
            </group>
          </group>
        </page>
      </xpath>
    </field>
  </record>

</odoo>
