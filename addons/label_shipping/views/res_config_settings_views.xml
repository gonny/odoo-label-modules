<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="res_config_settings_view_form_shipping" model="ir.ui.view">
    <field name="name">res.config.settings.view.form.inherit.shipping</field>
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="base.res_config_settings_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//form" position="inside">
        <app data-string="Zásilky" string="Zásilky" name="label_shipping" groups="base.group_system">

          <block title="Packeta (Zásilkovna)" name="shipping_packeta_settings">
            <setting id="shipping_packeta_password_setting" string="API Password" help="Heslo pro přístup k Packeta API">
              <field name="shipping_packeta_api_password" password="True"/>
            </setting>
            <setting id="shipping_packeta_indication_setting" string="Indication (eshop)" help="Název e-shopu odesílaný do Packeta API">
              <field name="shipping_packeta_indication"/>
            </setting>
          </block>

          <block title="DPD" name="shipping_dpd_settings">
            <setting id="shipping_dpd_key_setting" string="API Key" help="Klíč pro přístup k DPD API">
              <field name="shipping_dpd_api_key"/>
            </setting>
            <setting id="shipping_dpd_dsw_setting" string="API DSW" help="DSW token pro DPD API">
              <field name="shipping_dpd_api_dsw" password="True"/>
            </setting>
            <setting id="shipping_dpd_test_mode_setting" string="Test Mode" help="Používat testovací DPD API endpoint místo produkčního">
              <field name="shipping_dpd_test_mode"/>
            </setting>
          </block>

        </app>
      </xpath>
    </field>
  </record>

</odoo>
