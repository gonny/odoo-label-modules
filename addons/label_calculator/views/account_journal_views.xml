<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_journal_form_label" model="ir.ui.view">
        <field name="name">account.journal.form.label</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">

            <!-- Zpřístupnit Currency pole pro všechny -->
            <xpath expr="//field[@name='currency_id']" position="attributes">
                <attribute name="groups"/>
            </xpath>

            <!-- Zpřístupnit Default Account pro všechny -->
            <xpath expr="//field[@name='default_account_id'][1]" position="attributes">
                <attribute name="groups"/>
            </xpath>
            <xpath expr="//field[@name='default_account_id'][2]" position="attributes">
                <attribute name="groups"/>
            </xpath>

            <!-- Zpřístupnit labels pro Default Account -->
            <xpath expr="//label[@for='default_account_id'][@string='Bank Account']" position="attributes">
                <attribute name="groups"/>
            </xpath>
            <xpath expr="//label[@for='default_account_id'][@string='Cash Account']" position="attributes">
                <attribute name="groups"/>
            </xpath>
            <xpath expr="//label[@for='default_account_id'][@string='Default Income Account']" position="attributes">
                <attribute name="groups"/>
            </xpath>
            <xpath expr="//label[@for='default_account_id'][@string='Default Expense Account']" position="attributes">
                <attribute name="groups"/>
            </xpath>
            <xpath expr="//label[@for='default_account_id'][@string='Default Account']" position="attributes">
                <attribute name="groups"/>
            </xpath>
            <xpath expr="//label[@for='default_account_id'][@string='Journal Account']" position="attributes">
                <attribute name="groups"/>
            </xpath>

        </field>
    </record>

</odoo>
