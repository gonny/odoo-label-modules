<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="label_machine_view_form" model="ir.ui.view">
    <field name="name">label.machine.form</field>
    <field name="model">label.machine</field>
    <field name="arch" type="xml">
      <form string="Stroj">
        <sheet>
          <div class="oe_title">
            <h1>
              <field name="name" placeholder="Název stroje"/>
            </h1>
          </div>
          <group>
            <group string="Pořízení">
              <field name="purchase_price"/>
              <field name="lifetime_years"/>
            </group>
            <group string="Využití">
              <field name="working_days_per_week"/>
              <field name="hours_per_day"/>
              <field name="weeks_per_year"/>
            </group>
          </group>
          <group string="Vypočtená amortizace">
            <group>
              <field name="working_days_per_year" readonly="1"/>
              <field name="hours_per_year" readonly="1"/>
              <field name="total_lifetime_hours" readonly="1"/>
            </group>
            <group>
              <field name="hourly_amortization" readonly="1"/>
              <field name="daily_amortization" readonly="1"/>
            </group>
          </group>
          <field name="notes" placeholder="Poznámky..."/>
        </sheet>
      </form>
    </field>
  </record>

  <record id="label_machine_view_list" model="ir.ui.view">
    <field name="name">label.machine.list</field>
    <field name="model">label.machine</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="purchase_price"/>
        <field name="lifetime_years"/>
        <field name="hours_per_year"/>
        <field name="hourly_amortization" decoration-bf="1"/>
        <field name="daily_amortization"/>
      </list>
    </field>
  </record>

  <record id="label_machine_action" model="ir.actions.act_window">
    <field name="name">Stroje</field>
    <field name="res_model">label.machine</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>
