<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_partner_form_label" model="ir.ui.view">
    <field name="name">res.partner.form.label</field>
    <field name="model">res.partner</field>
    <field name="inherit_id" ref="base.view_partner_form"/>
    <field name="arch" type="xml">
      <xpath expr="//page[@name='internal_notes']" position="before">
        <page string="Štítky – slevy" name="label_discounts">
          <group>
            <group string="VIP status">
              <field name="label_is_vip"/>
              <field name="label_pricing_profile_id"
                     invisible="not label_is_vip"
                     domain="[('is_vip', '=', True)]"/>
              <div invisible="not label_vip_eligible or label_is_vip" class="text-warning fw-bold">
                ⭐ Nárok na VIP
              </div>
              <div invisible="not label_is_vip" class="text-success fw-bold">
                ⭐ <field name="label_pricing_profile_id" widget="text" readonly="1" nolabel="1" class="d-inline"/>
              </div>
              <field name="label_vip_eligible" invisible="1"/>
            </group>
          </group>
          <group>
            <group string="Automatická sleva">
              <field name="label_total_invoiced" widget="monetary"/>
              <field name="label_discount_tier_id"/>
            </group>
            <group string="Přetížení">
              <field name="label_discount_override" invisible="label_is_vip"/>
              <field name="label_effective_discount" widget="percentage"/>
            </group>
          </group>
        </page>
      </xpath>
    </field>
  </record>

</odoo>
