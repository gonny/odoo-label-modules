<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="label_material_group_view_form" model="ir.ui.view">
    <field name="name">label.material.group.form</field>
    <field name="model">label.material.group</field>
    <field name="arch" type="xml">
      <form string="Skupina materiálů">
        <sheet>
          <div class="oe_title">
            <h1>
              <field name="name" placeholder="Název skupiny"/>
            </h1>
          </div>

          <group>
            <group string="Nastavení">
              <field name="material_type"/>
              <field name="is_addon"/>
              <field name="machine_id"/>
              <field name="default_margin_pct"/>
              <field name="sequence"/>
            </group>
            <group string="Přehled">
              <field name="material_count"/>
              <field name="tier_count"/>
            </group>
          </group>

          <notebook>
            <page string="Materiály (barvy/varianty)" name="materials">
              <field name="material_ids">
                <list editable="bottom">
                  <field name="name"/>
                  <field name="color_name"/>
                  <field name="color_hex" optional="hide"/>
                  <field name="purchase_price"/>
                  <field name="purchase_vat_included"/>
                  <field name="purchase_price_excl_vat" optional="hide"/>
                  <field name="purchase_price_incl_vat" optional="hide"/>
                  <field name="sheet_width_mm" column_invisible="parent.material_type != 'area'" optional="show"/>
                  <field name="sheet_height_mm" column_invisible="parent.material_type != 'area'" optional="show"/>
                  <field name="thickness_mm" column_invisible="parent.material_type != 'area'" optional="hide"/>
                  <field name="roll_width_mm" column_invisible="parent.material_type != 'length'"/>
                  <field name="roll_length_m" column_invisible="parent.material_type != 'length'"/>
                  <field name="time_seconds" column_invisible="parent.material_type != 'time'"/>
                  <field name="time_multiplier" column_invisible="parent.material_type != 'time'"/>
                  <field name="component_price" column_invisible="parent.material_type != 'pieces'"/>
                  <field name="price_per_mm2" column_invisible="parent.material_type != 'area'" optional="show"/>
                  <field name="price_per_mm_length" column_invisible="parent.material_type != 'length'" optional="show"/>
                  <field name="price_per_second" column_invisible="parent.material_type != 'time'" optional="show"/>
                </list>
              </field>
            </page>

            <page string="Množstevní hladiny" name="tiers">
              <field name="tier_ids">
                <list editable="bottom">
                  <field name="name"/>
                  <field name="min_quantity"/>
                  <field name="max_quantity"/>
                  <field name="pieces_per_hour"/>
                  <field name="margin_pct"/>
                  <field name="waste_test_pieces"/>
                  <field name="waste_test_percentage"/>
                  <field name="waste_pruning_percentage"/>
                </list>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="label_material_group_view_list" model="ir.ui.view">
    <field name="name">label.material.group.list</field>
    <field name="model">label.material.group</field>
    <field name="arch" type="xml">
      <list>
        <field name="sequence" widget="handle"/>
        <field name="name"/>
        <field name="material_type"/>
        <field name="is_addon"/>
        <field name="machine_id"/>
        <field name="default_margin_pct"/>
        <field name="material_count"/>
        <field name="tier_count"/>
      </list>
    </field>
  </record>

  <record id="label_material_group_action" model="ir.actions.act_window">
    <field name="name">Skupiny materiálů</field>
    <field name="res_model">label.material.group</field>
    <field name="view_mode">list,form</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
                Přidej první skupinu materiálů
      </p>
    </field>
  </record>

</odoo>
