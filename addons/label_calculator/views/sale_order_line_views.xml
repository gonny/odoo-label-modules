<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="sale_order_form_view_label" model="ir.ui.view">
    <field name="name">sale.order.form.label</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">

      <!-- ============================================ -->
      <!-- SLOUPCE v inline list                        -->
      <!-- ============================================ -->
      <xpath expr="//field[@name='order_line']/list/field[@name='price_unit']" position="before">
        <field name="pricing_type" column_invisible="1"/>
        <field name="label_material_group_id" column_invisible="1"/>
        <field name="label_material_id" string="Varianta" optional="show"/>
        <field name="label_width_mm" optional="show"/>
        <field name="label_height_mm" optional="show"/>
        <field name="label_ttr_material_id" optional="hide"/>
        <field name="label_is_repeat_design" optional="hide"/>
        <field name="label_material_cost_only" string="Náklad mat." optional="show"/>
      </xpath>

      <!-- ============================================ -->
      <!-- POPUP formulář – breakdown                   -->
      <!-- ============================================ -->
      <xpath expr="//field[@name='order_line']/form//div[@name='invoice_lines']" position="after">
        <group string="Rozpad ceny" invisible="pricing_type != 'calculator'" name="label_breakdown_popup">
          <div colspan="2" style="white-space: pre-wrap; font-family: monospace; font-size: 12px; background: #f8f9fa; padding: 8px; border-radius: 4px;">
            <field name="label_price_breakdown" readonly="1" nolabel="1"/>
          </div>
        </group>
      </xpath>

      <!-- ============================================ -->
      <!-- ZÁLOŽKA "Kalkulace"                          -->
      <!-- ============================================ -->
      <xpath expr="//page[@name='order_lines']" position="after">
        <page string="Kalkulace" name="label_calculation_page">
          <field name="order_line" mode="list" readonly="1">
            <list create="0" delete="0" edit="0" decoration-muted="pricing_type != 'calculator'">
              <field name="pricing_type" column_invisible="1"/>
              <field name="product_template_id" string="Produkt"/>
              <field name="label_material_id" string="Varianta"/>
              <field name="label_width_mm" string="Šířka"/>
              <field name="label_height_mm" string="Výška"/>
              <field name="product_uom_qty" string="Ks"/>
              <field name="label_ttr_material_id" string="TTR"/>
              <field name="label_material_cost_only" string="Náklad mat./ks"/>
              <field name="price_unit" string="Cena/ks"/>
              <field name="price_subtotal" string="Celkem"/>
              <field name="label_price_breakdown" string="Rozpad ceny"/>
            </list>
          </field>
        </page>
      </xpath>

    </field>
  </record>

</odoo>
