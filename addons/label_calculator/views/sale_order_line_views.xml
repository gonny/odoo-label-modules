<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- ============================================ -->
  <!-- Standalone list view pro historii zákazníka   -->
  <!-- ============================================ -->
  <record id="view_label_history_list" model="ir.ui.view">
    <field name="name">sale.order.line.label.history.list</field>
    <field name="model">sale.order.line</field>
    <field name="arch" type="xml">
      <list create="0" delete="0" edit="0" default_group_by="label_order_display">
        <field name="label_order_display" column_invisible="1"/>
        <field name="order_id" string="Objednávka"/>
        <field name="create_date" string="Datum" widget="date"/>
        <field name="product_template_id" string="Produkt"/>
        <field name="label_material_id" string="Varianta"/>
        <field name="label_width_mm" string="Šířka"/>
        <field name="label_height_mm" string="Výška"/>
        <field name="product_uom_qty" string="Ks"/>
        <field name="label_ttr_material_id" string="TTR"/>
        <field name="price_unit" string="Cena/ks"/>
        <field name="price_subtotal" string="Celkem"/>
        <button name="action_copy_to_current_order" string="Kopírovat" type="object" icon="fa-copy" class="btn-link"/>
      </list>
    </field>
  </record>

  <!-- ============================================ -->
  <!-- Hlavní view rozšíření objednávky             -->
  <!-- ============================================ -->
  <record id="sale_order_form_view_label" model="ir.ui.view">
    <field name="name">sale.order.form.label</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">

      <!-- ============================================ -->
      <!-- SLOUPCE v inline list                        -->
      <!-- ============================================ -->
      <xpath expr="//field[@name='order_line']/list/field[@name='price_unit']" position="before">
        <field name="pricing_type" column_invisible="1"/>
        <field name="label_material_group_id" column_invisible="1"/>
        <field name="label_material_id" string="Varianta" optional="show"/>
        <field name="label_width_mm" optional="show"/>
        <field name="label_height_mm" optional="show"/>
        <field name="label_ttr_material_id" optional="hide"/>
        <field name="label_is_repeat_design" optional="hide"/>
        <field name="label_material_cost_only" string="Náklad mat." optional="show"/>
      </xpath>

      <!-- VIP badge near partner -->
      <xpath expr="//field[@name='partner_id']" position="after">
        <field name="label_pricing_profile_display" invisible="not label_pricing_profile_display" class="fw-bold text-success"/>
      </xpath>

      <!-- ============================================ -->
      <!-- ZÁLOŽKA "Kalkulace"                          -->
      <!-- ============================================ -->
      <xpath expr="//page[@name='order_lines']" position="after">
        <page string="Kalkulace" name="label_calculation_page">
          <field name="order_line" mode="list" readonly="1">
            <list create="0" delete="0" edit="0" decoration-muted="pricing_type != 'calculator'">
              <field name="pricing_type" column_invisible="1"/>
              <field name="product_template_id" string="Produkt"/>
              <field name="label_material_id" string="Varianta"/>
              <field name="label_width_mm" string="Šířka"/>
              <field name="label_height_mm" string="Výška"/>
              <field name="product_uom_qty" string="Ks"/>
              <field name="label_ttr_material_id" string="TTR"/>
              <field name="label_material_cost_only" string="Náklad mat./ks"/>
              <field name="price_unit" string="Cena/ks"/>
              <field name="price_subtotal" string="Celkem"/>
              <field name="label_price_breakdown" string="Rozpad ceny"/>
            </list>
          </field>
        </page>
      </xpath>

      <!-- ============================================ -->
      <!-- ZÁLOŽKA "Historie zákazníka"                 -->
      <!-- ============================================ -->
      <xpath expr="//page[@name='label_calculation_page']" position="after">
        <page string="Historie zákazníka" name="label_history_page" invisible="not partner_id">
          <div class="mb-3">
            <button name="action_open_partner_history" string="📂 Otevřít seskupenou historii" type="object" class="btn-secondary" icon="fa-external-link" invisible="not partner_id"/>
          </div>
          <field name="label_partner_history_ids" mode="list" readonly="1" context="{'active_order_id': id}">
            <list create="0" delete="0" edit="0">
              <field name="order_id" string="Objednávka"/>
              <field name="create_date" string="Datum" widget="date"/>
              <field name="product_template_id" string="Produkt"/>
              <field name="label_material_id" string="Varianta"/>
              <field name="label_width_mm" string="Šířka"/>
              <field name="label_height_mm" string="Výška"/>
              <field name="product_uom_qty" string="Ks"/>
              <field name="label_ttr_material_id" string="TTR"/>
              <field name="price_unit" string="Cena/ks"/>
              <field name="price_subtotal" string="Celkem"/>
              <button name="action_copy_to_current_order" string="Kopírovat" type="object" icon="fa-copy" class="btn-link"/>
            </list>
          </field>
        </page>
      </xpath>

    </field>
  </record>

</odoo>
