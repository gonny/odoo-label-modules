<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="label_material_view_form" model="ir.ui.view">
    <field name="name">label.material.form</field>
    <field name="model">label.material</field>
    <field name="arch" type="xml">
      <form string="Materiál">
        <sheet>
          <div class="oe_title">
            <h1>
              <field name="name" placeholder="Název"/>
            </h1>
          </div>
          <group>
            <group string="Základní info">
              <field name="group_id"/>
              <field name="material_type" readonly="1"/>
              <field name="color_name"/>
              <field name="color_hex"/>
            </group>
            <group string="Nákupní cena">
              <field name="purchase_price"/>
              <field name="purchase_vat_included"/>
              <field name="purchase_vat_pct"/>
              <field name="purchase_price_excl_vat" readonly="1"/>
              <field name="purchase_price_incl_vat" readonly="1"/>
            </group>
          </group>
          <group>
            <group string="Rozměry – Tabule/Arch" invisible="material_type != 'area'">
              <field name="sheet_width_mm"/>
              <field name="sheet_height_mm"/>
              <field name="thickness_mm"/>
              <field name="price_per_mm2" readonly="1"/>
            </group>
            <group string="Rozměry – Role" invisible="material_type != 'length'">
              <field name="roll_width_mm"/>
              <field name="roll_length_m"/>
              <field name="price_per_mm_length" readonly="1"/>
            </group>
            <group string="Čas" invisible="material_type != 'time'">
              <field name="time_seconds"/>
              <field name="time_multiplier"/>
              <field name="price_per_second" readonly="1"/>
            </group>
            <group string="Cena za kus" invisible="material_type != 'pieces'">
              <field name="component_price"/>
            </group>
          </group>
          <notebook>
            <page string="Přetížení hladin" name="overrides">
              <field name="tier_override_ids">
                <list editable="bottom">
                  <field name="tier_id"/>
                  <field name="pieces_per_hour_override"/>
                </list>
              </field>
            </page>
            <page string="Poznámky">
              <field name="production_notes" placeholder="Výrobní poznámky..."/>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="label_material_view_list" model="ir.ui.view">
    <field name="name">label.material.list</field>
    <field name="model">label.material</field>
    <field name="arch" type="xml">
      <list>
        <field name="group_id"/>
        <field name="name"/>
        <field name="color_name"/>
        <field name="material_type"/>
        <field name="purchase_price"/>
        <field name="purchase_vat_included"/>
        <field name="price_per_mm2" optional="show"/>
        <field name="price_per_mm_length" optional="show"/>
        <field name="price_per_second" optional="show"/>
        <field name="component_price" optional="show"/>
      </list>
    </field>
  </record>

  <record id="label_material_view_search" model="ir.ui.view">
    <field name="name">label.material.search</field>
    <field name="model">label.material</field>
    <field name="arch" type="xml">
      <search>
        <field name="name"/>
        <field name="color_name"/>
        <field name="group_id"/>
      </search>
    </field>
  </record>

  <record id="label_material_action" model="ir.actions.act_window">
    <field name="name">Materiály</field>
    <field name="res_model">label.material</field>
    <field name="view_mode">list,form</field>
    <field name="search_view_id" ref="label_material_view_search"/>
  </record>

</odoo>
