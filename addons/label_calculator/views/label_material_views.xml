<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- ============ FORMULÁŘ ============ -->
  <record id="label_material_view_form" model="ir.ui.view">
    <field name="name">label.material.form</field>
    <field name="model">label.material</field>
    <field name="arch" type="xml">
      <form string="Materiál">
        <sheet>
          <div class="oe_title">
            <h1>
              <field name="name" placeholder="Název materiálu"/>
            </h1>
          </div>

          <group>
            <group string="Základní info">
              <field name="material_type"/>
              <field name="color_name"/>
              <field name="color_hex"/>
              <field name="active" invisible="1"/>
            </group>

            <group string="Cena – Plošný materiál" invisible="material_type != 'sheet'">
              <field name="price_per_m2"/>
              <field name="thickness_mm"/>
              <field name="price_per_mm2" readonly="1"/>
            </group>

            <group string="Cena – Stuha" invisible="material_type != 'ribbon'">
              <field name="ribbon_width_mm"/>
              <field name="price_per_meter"/>
              <field name="price_per_mm_length" readonly="1"/>
            </group>

            <group string="Cena – TTR páska" invisible="material_type != 'ttr'">
              <field name="ttr_width_mm"/>
              <field name="ttr_length_m"/>
              <field name="ttr_price_per_roll"/>
              <field name="price_per_mm2" readonly="1"/>
            </group>

            <group string="Cena – Komponenta" invisible="material_type != 'component'">
              <field name="component_price"/>
            </group>
          </group>

          <notebook>
            <page string="Výrobní parametry" invisible="material_type not in ('sheet',)">
              <group>
                <field name="laser_power_pct"/>
                <field name="laser_speed"/>
              </group>
            </page>
            <page string="Poznámky">
              <field name="production_notes" placeholder="Jak se tento materiál chová při výrobě..."/>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <!-- ============ SEZNAM (list, NE tree!) ============ -->
  <record id="label_material_view_list" model="ir.ui.view">
    <field name="name">label.material.list</field>
    <field name="model">label.material</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="material_type"/>
        <field name="color_name"/>
        <field name="price_per_m2" optional="show"/>
        <field name="price_per_meter" optional="show"/>
        <field name="ttr_price_per_roll" optional="show"/>
        <field name="component_price" optional="show"/>
        <field name="price_per_mm2" optional="hide"/>
      </list>
    </field>
  </record>

  <!-- ============ VYHLEDÁVÁNÍ ============ -->
  <record id="label_material_view_search" model="ir.ui.view">
    <field name="name">label.material.search</field>
    <field name="model">label.material</field>
    <field name="arch" type="xml">
      <search>
        <field name="name"/>
        <field name="color_name"/>
        <filter name="filter_sheet" string="Plošný" domain="[('material_type', '=', 'sheet')]"/>
        <filter name="filter_ribbon" string="Stuha" domain="[('material_type', '=', 'ribbon')]"/>
        <filter name="filter_ttr" string="TTR" domain="[('material_type', '=', 'ttr')]"/>
        <filter name="filter_component" string="Komponenty" domain="[('material_type', '=', 'component')]"/>
        <group expand="0" string="Seskupit dle">
          <filter name="group_type" string="Typ materiálu" context="{'group_by': 'material_type'}"/>
        </group>
      </search>
    </field>
  </record>

  <!-- ============ AKCE ============ -->
  <record id="label_material_action" model="ir.actions.act_window">
    <field name="name">Materiály</field>
    <field name="res_model">label.material</field>
    <field name="view_mode">list,form</field>
    <field name="search_view_id" ref="label_material_view_search"/>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
                Přidej první materiál
      </p>
      <p>
                Materiály jsou základem kalkulace cen.
                Přidej plošné materiály, stuhy, TTR pásky a komponenty.
      </p>
    </field>
  </record>

</odoo>
