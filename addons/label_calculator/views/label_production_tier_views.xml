<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="label_production_tier_view_form" model="ir.ui.view">
    <field name="name">label.production.tier.form</field>
    <field name="model">label.production.tier</field>
    <field name="arch" type="xml">
      <form string="Hladina výroby">
        <sheet>
          <group>
            <group string="Hladina">
              <field name="group_id"/>
              <field name="name"/>
              <field name="min_quantity"/>
              <field name="max_quantity"/>
            </group>
            <group string="Výroba a marže">
              <field name="pieces_per_hour"/>
              <field name="margin_pct"/>
            </group>
          </group>
          <group string="Odpady">
            <group>
              <field name="waste_test_pieces"/>
              <field name="waste_test_percentage"/>
            </group>
            <group>
              <field name="waste_pruning_percentage"/>
            </group>
          </group>
          <field name="notes" placeholder="Poznámky..."/>
        </sheet>
      </form>
    </field>
  </record>

  <record id="label_production_tier_view_list" model="ir.ui.view">
    <field name="name">label.production.tier.list</field>
    <field name="model">label.production.tier</field>
    <field name="arch" type="xml">
      <list>
        <field name="group_id"/>
        <field name="name"/>
        <field name="min_quantity"/>
        <field name="max_quantity"/>
        <field name="pieces_per_hour" decoration-bf="1"/>
        <field name="margin_pct"/>
        <field name="waste_test_pieces"/>
        <field name="waste_test_percentage"/>
        <field name="waste_pruning_percentage"/>
      </list>
    </field>
  </record>

  <record id="label_production_tier_action" model="ir.actions.act_window">
    <field name="name">Množstevní hladiny</field>
    <field name="res_model">label.production.tier</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>
