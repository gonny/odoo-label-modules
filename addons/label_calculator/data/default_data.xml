<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">

    <!-- ============ VÝCHOZÍ HLADINY ============ -->
    <record id="tier_small" model="label.production.tier">
      <field name="name">Malá série</field>
      <field name="min_quantity">1</field>
      <field name="max_quantity">49</field>
      <field name="pieces_per_hour">500</field>
      <field name="waste_test_pieces">10</field>
    </record>

    <record id="tier_medium" model="label.production.tier">
      <field name="name">Střední série</field>
      <field name="min_quantity">50</field>
      <field name="max_quantity">99</field>
      <field name="pieces_per_hour">750</field>
      <field name="waste_test_pieces">5</field>
    </record>

    <record id="tier_large" model="label.production.tier">
      <field name="name">Velká série</field>
      <field name="min_quantity">100</field>
      <field name="max_quantity">499</field>
      <field name="pieces_per_hour">1000</field>
      <field name="waste_test_pieces">3</field>
    </record>

    <record id="tier_bulk" model="label.production.tier">
      <field name="name">Velkoobjem</field>
      <field name="min_quantity">500</field>
      <field name="max_quantity">999999</field>
      <field name="pieces_per_hour">1200</field>
      <field name="waste_test_pieces">2</field>
    </record>

    <!-- ============ VÝCHOZÍ STROJE ============ -->
    <record id="machine_laser" model="label.machine">
      <field name="name">Laser CO2</field>
      <field name="purchase_price">100000</field>
      <field name="lifetime_years">5</field>
      <field name="hours_per_year">1000</field>
    </record>

    <record id="machine_printer" model="label.machine">
      <field name="name">Tiskárna etiket</field>
      <field name="purchase_price">35000</field>
      <field name="lifetime_years">4</field>
      <field name="hours_per_year">800</field>
    </record>

    <!-- ============ UKÁZKOVÉ MATERIÁLY ============ -->
    <record id="mat_alu_05_silver" model="label.material">
      <field name="name">Hliník 0.5mm</field>
      <field name="material_type">sheet</field>
      <field name="color_name">Přírodní stříbrná</field>
      <field name="color_hex">#C0C0C0</field>
      <field name="price_per_m2">850</field>
      <field name="thickness_mm">0.5</field>
      <field name="laser_power_pct">80</field>
      <field name="laser_speed">500</field>
      <field name="production_notes">Standardní nastavení. Gravíruje se tmavý kontrast na světlém podkladu.</field>
    </record>

    <record id="mat_alu_05_black" model="label.material">
      <field name="name">Hliník 0.5mm</field>
      <field name="material_type">sheet</field>
      <field name="color_name">Černá eloxovaná</field>
      <field name="color_hex">#1a1a1a</field>
      <field name="price_per_m2">920</field>
      <field name="thickness_mm">0.5</field>
      <field name="laser_power_pct">40</field>
      <field name="laser_speed">800</field>
      <field name="production_notes">NÍZKÝ VÝKON! Gravíruje se světlý kontrast na tmavém podkladu. Pozor na přepálení.</field>
    </record>

    <record id="mat_satin_20_white" model="label.material">
      <field name="name">Satén 20mm</field>
      <field name="material_type">ribbon</field>
      <field name="color_name">Bílý</field>
      <field name="color_hex">#FFFFFF</field>
      <field name="ribbon_width_mm">20</field>
      <field name="price_per_meter">2.20</field>
    </record>

    <record id="mat_ttr_black" model="label.material">
      <field name="name">TTR páska</field>
      <field name="material_type">ttr</field>
      <field name="color_name">Černá</field>
      <field name="color_hex">#000000</field>
      <field name="ttr_width_mm">110</field>
      <field name="ttr_length_m">100</field>
      <field name="ttr_price_per_roll">350</field>
    </record>

    <record id="mat_rivet_brass" model="label.material">
      <field name="name">Nýt mosazný</field>
      <field name="material_type">component</field>
      <field name="color_name">Mosaz</field>
      <field name="color_hex">#B5A642</field>
      <field name="component_price">1.20</field>
    </record>

  </data>
</odoo>
